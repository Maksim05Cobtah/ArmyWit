@{
    ViewData["Title"] = "Про мене";
}
@model ArmiVit.Models.ViewsModel.AboutEditorViewModel   

<div class="about-page">

    <head>
        <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap"
              rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
              rel="stylesheet">



    </head>
            <form class="about-text" asp-controller="Admin" asp-action="TextUpdate">

    <!-- ПРО МЕНЕ -->
    <section class="section section-about">

        <div class="container about-grid">
            <div class="about-photo">
                <img src="~/images/angelika.jpg" alt="Анжеліка">
            </div>

                <h2 class="section-title">ПРО МЕНЕ</h2>
                <textarea asp-for="AboutMeText1" class="form-control" rows="4"></textarea>

                <br />
                <textarea asp-for="AboutMeText2" class="form-control" rows="4"></textarea>
                <br />
                <input type="submit" value="Зберегти" />


        </div>
    </section>

    <!-- ДОСВІД -->
    <section class="section section-experience">
        <div class="container">
            <h2 class="section-title center">ДОСВІД</h2>

           
               

                <textarea asp-for="ExpirienceText1" class="form-control" rows="4"></textarea>

                <input type="submit" value="Зберегти" />


    
                
            

            <div class="quote-box">
                <p>
                    Моє завдання — вчасно помітити сигнали організму та
                    скерувати вас до профільного лікаря, якщо це необхідно.
                </p>
            </div>

            <p>
                Якщо під час роботи я бачу показники або симптоми,
                що виходять за межі нутриціологічної корекції,
                я рекомендую консультацію профільного спеціаліста.
            </p>
        </div>
    </section>

    <section class="certificates-section">
        <div class="certificates-container">
            <h2 class="certificates-title">СЕРТИФІКАТИ</h2>

            <!-- тут згодом можна додати фото сертифікатів -->

            <div class="certificates-note">
                Я НЕ БУДУ : СТАВИТИ ДІАГНОЗИ, ПРИЗНАЧАТИ
                ЛІКИ ЧИ ЛІКУВАЛЬНІ ПРОЦЕДУРИ.
            </div>
        </div>
    </section>

    <section class="services">
        <!-- Заголовок ПОСЛУГИ -->
        <h2 class="services-title">ПОСЛУГИ</h2>

        <!-- ПОГЛИБЛЕНА КОНСУЛЬТАЦІЯ з описом і часом -->
        <div class="service-name-box">
            <span class="service-name">ПОГЛИБЛЕНА КОНСУЛЬТАЦІЯ</span>
            <span class="service-time">60ХВ</span>
            <p class="service-description">
                (визначаємо початковий стан організму, скерування на аналізи, рекомендації по харчуванню)
            </p>
        </div>

        <!-- Блок ТИ ОТРИМАЄШ -->
        <div class="receive-box">
            <h2 class="receive-title">ТИ ОТРИМАЄШ:</h2>
            <ul>
                <li>аналіз харчового статусу (без постановки діагнозів);</li>
                <li>розбір харчових звичок;</li>
                <li>рекомендації щодо базових змін раціону</li>
                <li>виявлення ключових помилок</li>
                <li>підбір нутрицевтиків</li>
            </ul>
        </div>

        <!-- Блок РЕЗУЛЬТАТ -->
        <div class="result-box">
            <h2 class="result-title">РЕЗУЛЬТАТ:</h2>
            <ul>
                <li>✔ чітке розуміння, що саме зараз шкодить здоров’ю</li>
                <li>✔ усвідомлення першопричин симптомів</li>
                <li>✔ напрямок, з чого починати зміни без крайнощів і дієт</li>
            </ul>
        </div>

        <!-- Ціна -->
        <div class="service-price">
            ЦІНА: 1000 ГРН
        </div>
    </section>

    <section class="program-section">
        <h1 class="program-title">СУПРОВІД</h1>
        <div class="programs">
            <div class="program-card">
                <h2>14 ДНІВ</h2>
                <div class="program-content">
                    <p><strong>У ПРОГРАМІ:</strong></p>
                    <ul>
                        <li>розбір тарілки</li>
                        <li>корекція харчування</li>
                        <li>постійний зворотний зв'язок</li>
                    </ul>
                    <p><strong>Результат:</strong></p>
                    <ul>
                        <li>✔ формування правильних харчових рішень</li>
                        <li>✔ зменшення хаосу в їжі</li>
                        <li>✔ відчуття підтримки та впевненості</li>
                    </ul>
                </div>
                <p class="price">1800ГРН</p>
            </div>

            <div class="program-card">
                <h2>30 ДНІВ</h2>
                <div class="program-content">
                    <p><strong>У ПРОГРАМІ:</strong></p>
                    <ul>
                        <li>детальний розбір харчування</li>
                        <li>корекція раціону</li>
                        <li>зворотний зв'язок протягом місяця</li>
                    </ul>
                    <p><strong>Результат:</strong></p>
                    <ul>
                        <li>✔ стабільні зміни без зривів</li>
                        <li>✔ розуміння свого організму</li>
                        <li>✔ навички, які залишаються після супроводу</li>
                    </ul>
                </div>
                <p class="price">4000ГРН</p>
            </div>
        </div>
    </section>


    </form>




</div>
