@using Microsoft.EntityFrameworkCore.Metadata.Internal
@{
    ViewData["Title"] = "Додати продукт";
}
@model ArmiVit.Models.ViewsModel.ProductViewModel

<section class="product-section">

    <div class="glass-card form-glass">

        <h2 class="title">Додати продукт</h2>

        <form method="post" asp-action="AddProduct" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div class="field">
                <label>Імʼя</label>
                <input asp-for="Name" />
            </div>

            <div class="field">
                <label>Ціна</label>
                <input asp-for="Price" type="number" step="0.01" placeholder="₴ 0.00" />
            </div>

            <div class="field">
                <label>Фото продукту</label>
                <input asp-for="ImageFile" type="file" accept="image/*" />
            </div>

            <div class="field">
                <label>Категорія</label>
                <select asp-for="CategoryId">
                    <option value="">Виберіть категорію</option>
                    @foreach (var category in Model.Categories ?? new List<Categories>())
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="glass-btn">
                Зберегти
            </button>

        </form>

    </div>

</section>


<section class="products-container">

    <div class="products-grid">

        @foreach (var item in Model.Products)
        {

            <div class="product-glass">

                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <div class="product-image">
                        <img src="~/images/@item.ImagePath" />
                    </div>
                }

                <div class="product-content">
                    <h3>@item.Name</h3>

                    <div class="price">
                        @item.Price ₴
                    </div>
                </div>

            </div>

        }

    </div>

</section>